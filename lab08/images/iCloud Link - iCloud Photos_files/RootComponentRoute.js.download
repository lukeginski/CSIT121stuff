/**
 * Buckets `n` to the order-of-magnitude version of it
 * (a number starting with an optional 1 and ending in
 * any number of 0s), retaining its sign, if < 0.
 *
 * @param n - The number to convert to order of magnitude
 * @returns A string representation of the order of magnitude
 *
 * @example
 * orderOfMagnitude(5)      // "10"
 * orderOfMagnitude(50)     // "100"
 * orderOfMagnitude(500)    // "100"
 * orderOfMagnitude(5000)   // "1000"
 * orderOfMagnitude(-500)   // "-100"
 * orderOfMagnitude(0.5)    // "0"
 * orderOfMagnitude(NaN)    // "0"
 * orderOfMagnitude(Infinity)  // "0"
 */
const orderOfMagnitude = n => {
  // Handle non-finite numbers (NaN, Infinity, -Infinity)
  if (!Number.isFinite(n)) return "0";
  const sign = Math.sign(n) === -1 ? "-" : "";
  n = Math.abs(n);
  if (n < 1) return `${sign}0`;
  return `${sign}1${"0".repeat(Math.floor(Math.log10(n)))}`;
};

/**
 * An integer, capped to its order of magnitude alone: a 1 or 0,
 * followed by zeroes, and potentially prefixed by a minus sign.
 */
