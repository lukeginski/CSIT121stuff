/**
 * ported from settings1 app findMe.js in models
 * Given an icon size in pixels, figure out the smallest icon that is larger than the
 * desired size, or if there are no larger icons, the largest icon
 * The motivation is that down-scaled icons look OK, but up-scaled icons don't.
 *
 * @param {Number} desiredSize in pixels of the (square) icon that we wish to retrieve
 * @param {Record<string, string>} iconURLs icon size to url map object
 * @returns {String} The URL of the best fitting icon found.
 */
function findIconURL(desiredSize, iconURLs) {
  let bestDelta, bestItem; // The best item found and it's associated error
  let largestSize, largestItem; // The largest item found and it's size

  for (let key in iconURLs) {
    // Get the size of the icon in pixels
    const iconSize = parseFloat(key);

    // Keep track of the largest icon
    if (!largestItem || !largestSize || iconSize > largestSize) {
      largestItem = iconURLs[key];
      largestSize = iconSize;
    }

    // Determine the difference between the icon's size and the desired size
    const delta = iconSize - desiredSize;

    // If the icon is larger than the desired size but smaller than anything we have seen so far
    if (bestDelta === undefined || delta >= 0 && delta < bestDelta) {
      // Remember this as the best we have seen
      bestDelta = delta;
      bestItem = iconURLs[iconSize];
    }
  }

  // Return the best icon found or if all icons are smaller then the largest item
  return bestItem || largestItem;
}
