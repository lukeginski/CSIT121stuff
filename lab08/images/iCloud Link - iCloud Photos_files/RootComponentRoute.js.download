// The crop rect definition used by MeCard API

// The crop rect definition used by UIImage, UIImagePicker and UIImagePickerButton

// Converts the MeCard image rect to UIImage image rect for profile image rendering
function convertImageCropRect(meCardCrop, imageSize) {
  let left = meCardCrop.x;
  let top = imageSize.height - meCardCrop.y - meCardCrop.height;
  const cropSize = Math.min(meCardCrop.width, meCardCrop.height);
  const width = cropSize;
  const height = cropSize;
  if (meCardCrop.width > meCardCrop.height) {
    left += (meCardCrop.width - meCardCrop.height) / 2;
  } else if (meCardCrop.height > meCardCrop.width) {
    top += (meCardCrop.height - meCardCrop.width) / 2;
  }
  return {
    top,
    left,
    width,
    height
  };
}

// Converts an UIImage rect to MeCard image rect for profile image uploading
function convertImageCropRectBackwards(rect, imageSize) {
  return {
    x: Math.round(rect.left),
    y: Math.round(imageSize.height - rect.top - rect.height),
    width: Math.round(rect.width),
    height: Math.round(rect.height)
  };
}

